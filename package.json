{
  "name": "angular-skeleton",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build @skt/core && ng build @skt/webapp",
    "build:nossr": "ng build @skt/core && ng build --configuration production,noSsr @skt/webapp",
    "core:storybook": "ng run @skt/core:storybook",
    "cy:webapp:run": "cypress run --project ./projects/webapp-e2e",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:code": "eslint \"./projects/**/*.ts\" \"./projects/**/*.html\"",
    "lint:code:fix": "eslint \"./projects/**/*.ts\" \"./projects/**/*.html\" --fix",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:styles:fix": "stylelint --fix \"**/*.scss\"",
    "lighthouse": "lighthouse --output-path=lighthouse-report.html http://localhost:4200",
    "ng": "ng",
    "serve:ssr:webapp": "node dist/webapp/server/server.mjs",
    "start:webapp": "ng serve --project @skt/webapp",
    "test": "ng test --browsers ChromeHeadless",
    "tools:check-format": "zx tools/check-format.mjs",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/ssr": "^18.2.2",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.2",
    "@angular/cli": "^18.2.2",
    "@angular/compiler-cli": "^18.2.0",
    "@chromatic-com/storybook": "^1.8.0",
    "@eslint/js": "^9.9.1",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-interactions": "^8.2.9",
    "@storybook/addon-links": "^8.2.9",
    "@storybook/addon-onboarding": "^8.2.9",
    "@storybook/angular": "^8.2.9",
    "@storybook/blocks": "^8.2.9",
    "@storybook/test": "^8.2.9",
    "@types/express": "^4.17.17",
    "@types/jasmine": "^5.1.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.18.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@web/test-runner": "^0.18.3",
    "angular-eslint": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "chalk": "^5.3.0",
    "cypress": "^13.14.1",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-storybook": "^0.8.0",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsonlint": "^1.6.3",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lighthouse": "^12.2.0",
    "ng-packagr": "^18.2.0",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "storybook": "^8.2.9",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.5.2",
    "typescript-eslint": "^8.3.0",
    "yaml": "^2.5.0",
    "zx": "^8.1.5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
